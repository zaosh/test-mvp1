# Database
DB_USER=testlab
DB_PASSWORD=
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@127.0.0.1:5432/testlab

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Seed passwords (required for prisma db seed — set before seeding)
SEED_ADMIN_PASSWORD=
SEED_QA_PASSWORD=
SEED_ENG_PASSWORD=
SEED_MANAGER_PASSWORD=

# GitHub
GITHUB_ORG_URL=https://github.com/your-org

# File uploads
UPLOAD_STORAGE_PATH=/var/testlab/uploads

# pgAdmin (dev only — never use in production)
PGADMIN_EMAIL=
PGADMIN_PASSWORD=
